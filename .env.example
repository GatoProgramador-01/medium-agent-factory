# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── MongoDB (Docker local) ────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=medium_agent_factory

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
FASTAPI_PORT=8000
NEXTJS_PORT=3000

# ── LangSmith (optional but recommended for tracing) ──────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=medium-agent-factory

# ── Local LLM via Ollama (optional) ───────────────────────────────────────────
# Set USE_LOCAL_LLM=true to run the entire pipeline locally (no Anthropic calls).
# Start Ollama: docker compose --profile local-llm up ollama -d
# Pull a model: docker compose exec ollama ollama pull llama3.2
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_BASE_URL=http://ollama:11434   # use http://localhost:11434 outside Docker

# ── Security ──────────────────────────────────────────────────────────────────
# CORS: comma-separated list of allowed frontend origins
# Production: set to your Vercel URL only  e.g. https://medium-agent-factory.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# Admin key bypasses the daily run limit (use for your own testing)
# Generate: openssl rand -hex 32
ADMIN_API_KEY=

# ── Cost Guards ───────────────────────────────────────────────────────────────
# Max pipeline + series runs per calendar day (global, all users combined)
# At ~$0.61/run, DAILY_RUN_LIMIT=20 caps daily spend at ~$12
DAILY_RUN_LIMIT=20

# Max Tavily fact-check searches per pipeline run
# Caps per-run Tavily cost to MAX_CLAIMS_PER_RUN × $0.001
MAX_CLAIMS_PER_RUN=8
