# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (web search for trend research) ────────────────────────────────────
# Free tier: 1000 searches/month — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Medium ────────────────────────────────────────────────────────────────────
# Settings > Security > Integration tokens
MEDIUM_ACCESS_TOKEN=your_medium_token_here
MEDIUM_USER_EMAIL=your@email.com
MEDIUM_USER_PASSWORD=your_password_here

# ── MongoDB (Docker local) ────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=medium_agent_factory

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
FASTAPI_PORT=8000
NEXTJS_PORT=3000

# ── LangSmith (optional but recommended for tracing) ──────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=medium-agent-factory
